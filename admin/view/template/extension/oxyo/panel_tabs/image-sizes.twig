<script type="text/javascript">
function buildConvertImagesMessage(json) {
	var message = json.success || '{{ text_convert_images_done|e('js') }}';
	message += ' {{ text_convert_images_result_renamed|e('js') }}: ' + (json.renamed || 0);
	message += ', {{ text_convert_images_result_db_updates|e('js') }}: ' + (json.db_updates || 0);
	message += ', {{ text_convert_images_result_cache_removed|e('js') }}: ' + (json.cache_removed || 0);

	if (json.errors && json.errors.length) {
		message += '. {{ text_convert_images_result_errors|e('js') }}: ' + json.errors.join(' | ');
	}

	return message;
}

function showConvertImagesResult($result, json) {
	if (json.error) {
		$result.addClass('alert-danger').text(json.error).show();
		return;
	}

	var message = buildConvertImagesMessage(json);

	$result.addClass('alert-success').text(message).show();
}

$('#button-convert-images-force').on('click', function() {
	if (!confirm('{{ text_confirm_convert_images|e('js') }}')) {
		return;
	}

	var $button = $(this);
	var $result = $('#convert-images-result');

	$button.prop('disabled', true);
	$result.removeClass('alert-success alert-danger').hide();

	$.ajax({
		url: '{{ action_convert_images|replace({'&amp;': '&'}) }}',
		type: 'post',
		data: {
			dry_run: $('#convert-images-dry-run').is(':checked') ? 1 : 0,
			enable_convert_log: $('#convert-images-enable-log').is(':checked') ? 1 : 0
		},
		dataType: 'json',
		complete: function() {
			$button.prop('disabled', false);
		},
		success: function(json) {
			showConvertImagesResult($result, json);
		},
		error: function(xhr) {
			var message = '{{ text_convert_images_error|e('js') }}';
			message += ' HTTP ' + (xhr && xhr.status ? xhr.status : 0);

			if (xhr && xhr.responseText) {
				message += ' | ' + xhr.responseText.replace(/\s+/g, ' ').substr(0, 350);
			}

			$result.addClass('alert-danger').text(message).show();
		}
	});
});
</script>