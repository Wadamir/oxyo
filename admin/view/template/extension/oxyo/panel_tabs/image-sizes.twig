<legend>{{ text_image_sizes_settings }}</legend>

<div class="form-field radio-switcher">
	<p class="radio-switcher-title">
        <span class="title">{{ entry_oxyo_optimize_images }}</span>
        <i class="bi bi-question-circle-fill" data-toggle="tooltip" title="{{ entry_oxyo_optimize_images }}"></i>
    </p>
	<div class="form-radio-switcher-wrapper">
		<label class="label-switcher label-switcher-pre" for="oxyo_optimize_images_0">{{ text_disabled }}</label>
		<div class="form-radio form-radio-inline form-radio-switcher">
            <input type="radio" name="settings[oxyo][oxyo_optimize_images]" value="0" {% if oxyo_optimize_images == '0' %} checked="checked" {% endif %} id="oxyo_optimize_images_0"/>
            <input type="radio" name="settings[oxyo][oxyo_optimize_images]" value="1" {% if oxyo_optimize_images == '1' %} checked="checked" {% endif %} id="oxyo_optimize_images_1"/>
		</div>
		<label class="label-switcher label-switcher-post" for="oxyo_optimize_images_1">{{ text_enabled }}</label>
	</div>
</div>

<div class="form-group">
	<label class="col-sm-2 control-label">{{ button_convert_images_force }}</label>
	<div class="col-sm-10">
		<div class="checkbox" style="margin-top:0;">
			<label>
				<input type="checkbox" id="convert-images-dry-run" value="1" /> {{ entry_convert_images_dry_run }}
			</label>
		</div>
		<div class="checkbox" style="margin-top:0;">
			<label>
				<input type="checkbox" id="convert-images-enable-log" value="1" checked="checked" /> {{ entry_convert_images_log }}
			</label>
		</div>
		<button type="button" id="button-convert-images-force" class="btn btn-danger">{{ button_convert_images_force }}</button>
		<p class="help-block">{{ text_convert_images_processing }}</p>
		<div id="convert-images-result" class="alert" style="display:none;margin-top:10px;"></div>
	</div>
</div>

