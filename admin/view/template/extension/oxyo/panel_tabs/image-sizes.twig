				<button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
				<h4 class="modal-title">{{ text_convert_images_progress_title }}</h4>
			</div>
			<div class="modal-body">
				<pre id="convert-images-progress-log" style="max-height:420px;overflow:auto;white-space:pre-wrap;"></pre>
			</div>
		</div>
	</div>
</div>

