              </fieldset>
              <fieldset>
                <legend>{{ text_returns_data }}</legend>
                {% for field in returns_status_fields %}
                {{ smp.select_field(field, attribute(_context, field.name), error_fields, text_enabled, text_disabled)|raw }}
