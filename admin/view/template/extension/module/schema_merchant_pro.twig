                </div>
                <div class="form-group{% if error_fields.module_schema_merchant_pro_organization_opening_opens is defined or error_fields.module_schema_merchant_pro_organization_opening_closes is defined %} has-error{% endif %}">
                  <label class="col-sm-2 control-label"><span data-toggle="tooltip" title="{{ help_field_organization_opening_opens }} {{ help_field_organization_opening_closes }}">{{ entry_organization_opening_hours_enabled }}</span></label>
