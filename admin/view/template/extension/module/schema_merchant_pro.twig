                <div class="smp-dependent-group" data-switch="input-module-schema-merchant-pro-returns-enabled">
                  <div class="form-group{% if error_fields.module_schema_merchant_pro_returns_country is defined or error_fields.module_schema_merchant_pro_returns_category is defined or error_fields.module_schema_merchant_pro_returns_days is defined %} has-error{% endif %}">
                    <label class="col-sm-2 control-label"><span data-toggle="tooltip" title="{{ help_field_returns_country }} {{ help_field_returns_category }} {{ help_field_returns_days }}">{{ text_returns_data }}</span></label>
