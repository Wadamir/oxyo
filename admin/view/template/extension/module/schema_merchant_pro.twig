                </div>
                {% if schema_merchant_pro_preview_product_name %}
                <p class="help-block">{{ schema_merchant_pro_preview_product_name }}</p>
                {% endif %}
                <textarea rows="18" readonly="readonly" class="form-control" style="font-family: Consolas, Monaco, monospace;">{{ schema_merchant_pro_preview_json }}</textarea>
              </fieldset>
              <fieldset>
                <legend>{{ text_diagnostics }}</legend>
                <div class="table-responsive">
                  <table class="table table-bordered table-hover">
                    <tbody>
                      {% for item in diagnostics %}
                      <tr>
                        <td style="width: 160px;">
                          {% if item.status == 'ok' %}
                          <span class="label label-success">{{ item.label }}</span>
                          {% elseif item.status == 'error' %}
                          <span class="label label-danger">{{ item.label }}</span>
                          {% else %}
                          <span class="label label-warning">{{ item.label }}</span>
                          {% endif %}
                        </td>
                        <td>{{ item.message }}</td>
                      </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
              </fieldset>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
$(function() {
  $('.smp-dependent-group').each(function() {
    var $group = $(this);
    var $switch = $('#' + $group.data('switch'));

    var toggleGroup = function() {
      $group.toggle($switch.is(':checked'));
    };

    $switch.on('change', toggleGroup);
    toggleGroup();
  });
});
//--></script>
{{ footer }}
