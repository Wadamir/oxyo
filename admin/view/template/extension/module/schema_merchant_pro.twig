{% macro select_field(field, current_value, error_fields, text_enabled, text_disabled) %}
<div class="form-group{% if error_fields[field.name] is defined %} has-error{% endif %}">
  <label class="col-sm-2 control-label" for="input-{{ field.name|replace({'_': '-'}) }}">{% if field.help %}<span data-toggle="tooltip" title="{{ field.help }}">{{ field.label }}</span>{% else %}{{ field.label }}{% endif %}</label>
  <div class="col-sm-10">
    {% if field.type is defined and field.type == 'switch' %}
    <input type="hidden" name="{{ field.name }}" value="0" />
    <label class="smp-switch" for="input-{{ field.name|replace({'_': '-'}) }}">
      <input type="checkbox" role="switch" name="{{ field.name }}" value="1" id="input-{{ field.name|replace({'_': '-'}) }}"{% if current_value == '1' or current_value == 1 %} checked="checked"{% endif %} />
      <span class="smp-switch-slider">
        <span class="smp-switch-state smp-switch-state-on">{{ text_enabled }}</span>
        <span class="smp-switch-state smp-switch-state-off">{{ text_disabled }}</span>
      </span>
    </label>
    {% else %}
    <select name="{{ field.name }}" id="input-{{ field.name|replace({'_': '-'}) }}" class="form-control">
      {% for option in field.options %}
      <option value="{{ option.value }}"{% if current_value == option.value %} selected="selected"{% endif %}>{{ option.text }}</option>
      {% endfor %}
    </select>
    {% endif %}
  </div>
</div>
{% endmacro %}

{% macro text_field(field, current_value, error_fields) %}
<div class="form-group{% if error_fields[field.name] is defined %} has-error{% endif %}">
  <label class="col-sm-2 control-label" for="input-{{ field.name|replace({'_': '-'}) }}">{% if field.help %}<span data-toggle="tooltip" title="{{ field.help }}">{{ field.label }}</span>{% else %}{{ field.label }}{% endif %}</label>
  <div class="col-sm-10">
    <input type="text" name="{{ field.name }}" value="{{ current_value }}" id="input-{{ field.name|replace({'_': '-'}) }}" class="form-control"{% if field.placeholder is defined and field.placeholder %} placeholder="{{ field.placeholder }}"{% endif %} />
  </div>
</div>
{% endmacro %}

{% import _self as smp %}
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-schema-merchant-pro" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-cog"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <style>
          .smp-switch {
            display: inline-block;
            position: relative;
            min-width: 118px;
            height: 32px;
            margin: 0;
            cursor: pointer;
            vertical-align: middle;
          }
          .smp-switch input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
          }
          .smp-switch-slider {
            position: absolute;
            inset: 0;
            border-radius: 16px;
            background: #d9534f;
            box-shadow: inset 0 0 0 1px rgba(0,0,0,.12);
            color: #fff;
            font-size: 12px;
            font-weight: 600;
            line-height: 32px;
            overflow: hidden;
            transition: background .18s ease;
          }
          .smp-switch-slider:before {
            content: "";
            position: absolute;
            width: 26px;
            height: 26px;
            left: 3px;
            top: 3px;
            border-radius: 50%;
            background: #fff;
            box-shadow: 0 1px 3px rgba(0,0,0,.28);
            transition: transform .18s ease;
            z-index: 2;
          }
          .smp-switch input:checked + .smp-switch-slider {
            background: #5cb85c;
          }
          .smp-switch input:checked + .smp-switch-slider:before {
            transform: translateX(86px);
          }
          .smp-switch-state {
            position: absolute;
            top: 0;
            width: 78px;
            text-align: center;
            transition: opacity .18s ease;
          }
          .smp-switch-state-on {
            left: 10px;
            opacity: 0;
          }
          .smp-switch-state-off {
            right: 8px;
            opacity: 1;
          }
          .smp-switch input:checked + .smp-switch-slider .smp-switch-state-on {
            opacity: 1;
          }
          .smp-switch input:checked + .smp-switch-slider .smp-switch-state-off {
            opacity: 0;
          }
          .has-error .smp-switch-slider,
          .has-error .form-control {
            border-color: #a94442;
          }
          .smp-weekday-list {
            padding-top: 7px;
          }
          .smp-weekday-list .checkbox-inline {
            margin: 0 14px 8px 0;
          }
          .smp-weekday-list .checkbox-inline + .checkbox-inline {
            margin-left: 0;
          }
          .smp-paired-inputs .input-group {
            margin-bottom: 8px;
          }
          .smp-paired-inputs .input-group-addon {
            min-width: 95px;
            text-align: left;
          }
          .smp-grid-inputs .input-group,
          .smp-grid-inputs .form-control {
            margin-bottom: 8px;
          }
          .smp-grid-inputs .input-group .form-control {
            margin-bottom: 0;
          }
          .smp-grid-inputs .input-group-addon {
            min-width: 130px;
            text-align: left;
          }
          @media (min-width: 768px) {
            .smp-paired-inputs .input-group {
              margin-bottom: 0;
            }
            .smp-grid-inputs .input-group,
            .smp-grid-inputs .form-control {
              margin-bottom: 0;
            }
          }
          .nav-tabs > li.smp-tab-error > a,
          .nav-tabs > li.smp-tab-error > a:hover,
          .nav-tabs > li.smp-tab-error > a:focus {
            color: #a94442;
            font-weight: 600;
          }
          .nav-tabs > li.smp-tab-error > a:before {
            content: "\f06a";
            font-family: FontAwesome;
            margin-right: 5px;
          }
        </style>
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-schema-merchant-pro" class="form-horizontal">
