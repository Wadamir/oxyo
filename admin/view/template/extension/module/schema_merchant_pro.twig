            <li{% if error_tabs.website is defined %} class="smp-tab-error"{% endif %}><a href="#tab-website" data-toggle="tab">{{ tab_website }}</a></li>
            <li{% if error_tabs.product is defined %} class="smp-tab-error"{% endif %}><a href="#tab-product" data-toggle="tab">{{ tab_product }}</a></li>
