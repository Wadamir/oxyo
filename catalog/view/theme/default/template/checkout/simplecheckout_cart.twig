	<input type="hidden" name="remove" value="" id="simplecheckout_remove"> <div style="display:none;" id="simplecheckout_cart_total">{{ cart_total }}</div>
	{% if display_weight %}
		<div style="display:none;" id="simplecheckout_cart_weight">{{ weight }}</div>
	{% endif %}
	{% if not display_model %}
		<style>
			.simplecheckout-cart col.model,
			.simplecheckout-cart th.model,
			.simplecheckout-cart td.model {
				display: none;
			}
		</style>
