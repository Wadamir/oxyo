<div class="simplecheckout-block" id="simplecheckout_cart" {{ hide ? 'data-hide="true"' : '' }} {{ has_error ? 'data-error="true"' : '' }}>
	{% if display_header %}
		<div id="cart_heading" class="xd_checkout-heading">
			<span>{{ text_cart }}</span>
			<span class="checkout-heading-button">
				<a href="javascript:void(0)" data-onclick="clearCart" class="text-danger" data-confirm-text="{{ text_clear_cart_question }}">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-circle-fill" viewbox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/></svg>
				</a>
			</span>
		</div>
	{% endif %}
	{% if attention %}
		<div class="alert alert-danger simplecheckout-warning-block">{{ attention }}</div>
	{% endif %}
	{% if error_warning %}
		<div class="alert alert-danger simplecheckout-warning-block">{{ error_warning }}</div>
	{% endif %}
	<div class="xd_checkout-cart">
		{% if products or vouchers %}
			<!-- Products -->
			{% for product in products %}
				<div class="xd_checkout-row">
					<div class="xd_checkout-cell_group">
						<div class="xd_checkout-cell image" style="max-width: {{ img_width }}px;">
							{% if product.thumb %}
								<a href="{{ product.href }}">
									<img src="{{ product.thumb }}" alt="{{ product.name }}" title="{{ product.name }}"/>
								</a>
							{% endif %}
						</div>
						<div class="xd_checkout-cell_vertical" style="width: calc(100% - {{ img_width }}px - 12px);">
							<div class="xd_checkout-cell name">
								<a href="{{ product.href }}">{{ product.name }}</a>
								<div>
									{% for option in product.option %}
										<small>{{ option.name }}:
											{{ option.value }}</small>
									{% endfor %}
									{% if product.reward %}
										<small>{{ product.reward }}</small>
									{% endif %}
									{% if product.recurring %}
										<span class="label label-info">{{ text_recurring_item }}</span>
										<small>{{ product.recurring }}</small>
									{% endif %}
								</div>
							</div>
							<div class="xd_checkout-cell_horizontal">
								<div class="xd_checkout-cell quantity">
									{{ product.price }}&nbsp;x&nbsp;{{ product.quantity }}
								</div>
								<div class="xd_checkout-cell total text-right">{{ product.total }}</div>
							</div>
						</div>
					</div>
				</div>
			{% endfor %}

			<!-- Vouchers -->
			{% for voucher in vouchers %}
				<div class="xd_checkout-row">
					<div class="xd_checkout-cell image"></div>
					<div class="xd_checkout-cell name">{{ voucher.description }}</div>
					<div class="xd_checkout-cell quantity">x&nbsp;1</div>
					<div class="xd_checkout-cell price1">{{ voucher.amount }}</div>
					<div class="xd_checkout-cell total">{{ voucher.amount }}</div>
				</div>
			{% endfor %}
		{% endif %}
	</div>
	<!-- Totals -->
	<div class="total-list margin-b0">
		{% for total in totals %}
			<div class="xd_checkout-row" id="total_{{ total.code }}">
				<div class="xd_checkout-cell text-left" style="flex: 3">
					<b>{{ total.title }}:</b>
				</div>
				<div class="xd_checkout-cell text-right" style="flex: 1">{{ total.text }}</div>
				{% if total['code'] == 'coupon' %}
					<div class="simplecheckout-cart-total-remove">
						<i data-onclick="removeCoupon" title="{{ button_remove }}" class="fa fa-times-circle"></i>
					</div>
				{% endif %}
				{% if total['code'] == 'voucher' %}
					<div class="simplecheckout-cart-total-remove">
						<i data-onclick="removeVoucher" title="{{ button_remove }}" class="fa fa-times-circle"></i>
					</div>
				{% endif %}
				{% if total['code'] == 'reward' %}
					<div class="simplecheckout-cart-total-remove">
						<i data-onclick="removeReward" title="{{ button_remove }}" class="fa fa-times-circle"></i>
					</div>
				{% endif %}
			</div>
		{% endfor %}
	</div>

